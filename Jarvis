<div id="toast"></div>

<script>
/* ═══════════════════════════════════════════
   CONSTANTS
═══════════════════════════════════════════ */
const RESET_WORD = 'Baunatal';
const DEF_PW     = '1234';
const GOVEE      = 'https://developer-api.govee.com/v1';

const DEMO = [
  {id:'d1',name:'Wohnzimmer Strip',model:'H6002',room:'Wohnzimmer',on:true, br:70, color:'#63b3ed',scene:''},
  {id:'d2',name:'Gaming Light Bar', model:'H6076',room:'Gaming',    on:true, br:100,color:'#b794f4',scene:'Gaming'},
  {id:'d3',name:'Schlafzimmer',     model:'H6601',room:'Schlafen',  on:false,br:40, color:'#f6ad55',scene:''},
  {id:'d4',name:'Desk Light',       model:'H6065',room:'Gaming',    on:true, br:60, color:'#68d391',scene:''},
];

const COLS = [
  {l:'Weiß',h:'#ffffff'},{l:'Warmweiß',h:'#ffd28f'},{l:'Rot',h:'#fc8181'},
  {l:'Orange',h:'#f6ad55'},{l:'Gelb',h:'#faf089'},{l:'Grün',h:'#68d391'},
  {l:'Cyan',h:'#76e4f7'},{l:'Blau',h:'#63b3ed'},{l:'Violett',h:'#b794f4'},{l:'Pink',h:'#f687b3'},
];
const SCENES = ['Lesen','Film','Gaming','Party','Entspannen','Romantisch','Konzentrieren'];

/* ═══════════════════════════════════════════
   STATE
═══════════════════════════════════════════ */
const S = {
  page:'home', room:'all',
  devices:[], goveeKey:'', defDev:'',
  cfg:{ speech:true, tts:true, anim:true, vol:80, wakeword:false, lock:true },
  theme:'dark', pw:DEF_PW,
  hist:[], // chat history
};

/* ═══════════════════════════════════════════
   STORAGE
═══════════════════════════════════════════ */
function load(){
  try{
    const d=JSON.parse(localStorage.getItem('jv3')||'{}');
    if(d.goveeKey) S.goveeKey=d.goveeKey;
    if(d.defDev)   S.defDev=d.defDev;
    if(d.cfg)      Object.assign(S.cfg,d.cfg);
    if(d.theme)    S.theme=d.theme;
    if(d.pw)       S.pw=d.pw;
    S.devices=(d.devices&&d.devices.length)?d.devices:[...DEMO];
    if(d.hist)     S.hist=d.hist;
  }catch(e){ S.devices=[...DEMO]; }
  applyTheme();
}
function save(){
  try{ localStorage.setItem('jv3',JSON.stringify({
    goveeKey:S.goveeKey,defDev:S.defDev,cfg:S.cfg,theme:S.theme,pw:S.pw,
    devices:S.devices, hist:S.hist.slice(-40),
  })); }catch(e){}
}

/* ═══════════════════════════════════════════
   LOCK
═══════════════════════════════════════════ */
function lkKey(e){ if(e.key==='Enter') lkCheck(); }
function lkCheck(){
  const v=document.getElementById('lki').value;
  const err=document.getElementById('lkerr');
  if(v===RESET_WORD){
    S.pw=DEF_PW; save();
    err.style.color='var(--green)';
    err.textContent='Passwort zurückgesetzt → 1234';
    document.getElementById('lki').value='';
    setTimeout(()=>{ err.textContent=''; err.style.color='var(--red)'; },2500);
    return;
  }
  if(v===S.pw){
    document.getElementById('lock').classList.add('gone');
    document.getElementById('lki').value=''; err.textContent='';
    if(S.cfg.wakeword) setTimeout(startWW,800);
  } else {
    err.textContent='Falsches Passwort.';
    document.getElementById('lki').value='';
    setTimeout(()=>err.textContent='',2200);
  }
}
function togLk(){
  S.cfg.lock=!S.cfg.lock;
  document.getElementById('tlk').classList.toggle('on',S.cfg.lock);
  save(); toast(S.cfg.lock?'Passwortschutz aktiviert.':'Passwortschutz deaktiviert.');
}
function chgPw(){
  const v=document.getElementById('newpw').value.trim();
  if(!v){ toast('Bitte ein Passwort eingeben.'); return; }
  S.pw=v; save();
  document.getElementById('newpw').value='';
  toast('Passwort gespeichert.');
}
function resetPw(){ S.pw=DEF_PW; save(); toast('Passwort zurückgesetzt auf: 1234'); }

/* ═══════════════════════════════════════════
   INIT
═══════════════════════════════════════════ */
window.addEventListener('DOMContentLoaded',()=>{
  load(); clock(); setInterval(clock,1000);
  renderDevices(); renderSettings(); welcome(); homeStats();
  if(S.cfg.lock){ /* lock screen already visible */ }
  else {
    document.getElementById('lock').classList.add('gone');
    if(S.cfg.wakeword) setTimeout(startWW,800);
  }
});

/* ═══════════════════════════════════════════
   CLOCK
═══════════════════════════════════════════ */
function clock(){
  const n=new Date();
  document.getElementById('ct').textContent=p2(n.getHours())+':'+p2(n.getMinutes());
  const ds=['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'];
  const ms=['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  document.getElementById('cd').textContent=`${ds[n.getDay()]}, ${n.getDate()}. ${ms[n.getMonth()]} ${n.getFullYear()}`;
}
function p2(n){ return String(n).padStart(2,'0'); }
function nt(){ const n=new Date(); return p2(n.getHours())+':'+p2(n.getMinutes()); }

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
function navigate(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(x=>x.classList.remove('on'));
  document.getElementById('page-'+p).classList.add('active');
  document.getElementById('nb-'+p).classList.add('on');
  S.page=p;
  if(p==='chat') setTimeout(()=>{ document.getElementById('msgs').scrollTop=99999; document.getElementById('ci').focus(); },80);
  if(p==='smarthome') renderDevices();
  if(p==='home') homeStats();
}

function homeStats(){
  document.getElementById('hdc').textContent=S.devices.length;
  document.getElementById('hdo').textContent=S.devices.filter(d=>d.on).length;
}

/* ═══════════════════════════════════════════
   CHAT
═══════════════════════════════════════════ */
function welcome(){
  if(!S.hist.length){
    const h=new Date().getHours();
    jMsg(h<12?'Guten Morgen! Ich bin Jarvis.':h<18?'Guten Tag! Ich bin Jarvis.':'Guten Abend! Ich bin Jarvis.'
      +' Wie kann ich Ihnen helfen?');
  } else {
    S.hist.forEach(m=>renderMsg(m.r,m.c,m.t));
  }
}

function jMsg(txt){
  const t=nt();
  S.hist.push({r:'j',c:txt,t});
  renderMsg('j',txt,t);
  if(S.cfg.tts) speak(txt);
  save();
}

function renderMsg(r,txt,t){
  const el=document.getElementById('msgs');
  const d=document.createElement('div');
  d.className='msg '+(r==='j'?'j':'u');
  d.innerHTML=`<div class="av">${r==='j'?'J':'Du'}</div><div><div class="bub">${esc(txt)}</div><div class="mt">${t}</div></div>`;
  el.appendChild(d); el.scrollTop=el.scrollHeight;
}

function showTyping(){
  const el=document.getElementById('msgs');
  const d=document.createElement('div');
  d.className='msg j'; d.id='typm';
  d.innerHTML='<div class="av">J</div><div><div class="bub"><div class="ti"><span></span><span></span><span></span></div></div></div>';
  el.appendChild(d); el.scrollTop=el.scrollHeight;
}
function rmTyping(){ const e=document.getElementById('typm'); if(e) e.remove(); }

async function sendMsg(){
  const inp=document.getElementById('ci');
  const txt=inp.value.trim(); if(!txt) return;
  inp.value=''; ar(inp);
  const t=nt();
  S.hist.push({r:'u',c:txt,t});
  renderMsg('u',txt,t); save();

  const local=handleCmd(txt);
  if(local){ showTyping(); await sleep(480); rmTyping(); jMsg(local); return; }

  showTyping(); setSt('Denkt …');
  try{ const r=await callClaude(txt); rmTyping(); jMsg(r); }
  catch(e){ rmTyping(); jMsg('Verbindung fehlgeschlagen. Bitte erneut versuchen.'); }
  setSt('Bereit');
}

function ckd(e){ if(e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); sendMsg(); } }
function ar(el){ el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,120)+'px'; }
function clearChat(){ S.hist=[]; document.getElementById('msgs').innerHTML=''; save(); jMsg('Chat geleert. Wie kann ich helfen?'); }

/* ═══════════════════════════════════════════
   LOCAL COMMANDS
═══════════════════════════════════════════ */
function handleCmd(raw){
  const t=raw.toLowerCase();
  if(/licht (an|ein)|alle.*an|einschalten/.test(t)){ const tg=getTgt(t); tg.forEach(d=>d.on=true); afterDev(tg,'on'); return `${tg.length>1?tg.length+' Geräte':tg[0]?.name||'Gerät'} eingeschaltet.`; }
  if(/licht (aus)|alle.*aus|ausschalten/.test(t)){ const tg=getTgt(t); tg.forEach(d=>d.on=false); afterDev(tg,'off'); return `${tg.length>1?tg.length+' Geräte':tg[0]?.name||'Gerät'} ausgeschaltet.`; }
  const cm=t.match(/(?:farbe|auf|stelle.*auf|color).*?(weiß|warmweiß|rot|orange|gelb|grün|cyan|blau|violett|pink|purple|blue|red|green|white)/);
  if(cm){ const map={weiß:'#ffffff',warmweiß:'#ffd28f',rot:'#fc8181',orange:'#f6ad55',gelb:'#faf089',grün:'#68d391',cyan:'#76e4f7',blau:'#63b3ed',violett:'#b794f4',pink:'#f687b3',purple:'#b794f4',blue:'#63b3ed',red:'#fc8181',green:'#68d391',white:'#ffffff'}; const c=map[cm[1]]; if(c){ const tg=getTgt(t); tg.forEach(d=>{d.color=c;d.on=true;}); afterDev(tg,'color',{color:c}); return `Farbe auf ${cm[1]} gesetzt.`; } }
  const bm=t.match(/(\d+)\s*%|helligkeit.*?(\d+)/);
  if(bm&&(t.includes('hell')||t.includes('%'))){ const v=parseInt(bm[1]||bm[2]); if(!isNaN(v)){ const tg=getTgt(t); tg.forEach(d=>d.br=Math.max(0,Math.min(100,v))); afterDev(tg,'brightness',{brightness:v}); return `Helligkeit auf ${v}% gesetzt.`; } }
  if(/gemütlich|cozy|chill/.test(t)){ const tg=getTgt(t); tg.forEach(d=>{d.on=true;d.color='#ffd28f';d.br=30;d.scene='Entspannen';}); afterDev(tg,'color',{color:'#ffd28f'}); return 'Gemütliche Atmosphäre: Warmweiß, 30%.'; }
  if(/gaming|gamer/.test(t)){ S.devices.forEach(d=>{d.on=true;d.color=d.name.toLowerCase().includes('strip')||d.name.toLowerCase().includes('bar')?'#63b3ed':d.name.toLowerCase().includes('desk')?'#76e4f7':'#ffffff';d.scene='Gaming';}); afterDev(S.devices,'color',{color:'#63b3ed'}); return 'Gaming-Modus aktiviert.'; }
  if(/wie spät|uhrzeit|wie viel uhr/.test(t)){ const n=new Date(); return `Es ist ${p2(n.getHours())}:${p2(n.getMinutes())} Uhr.`; }
  return null;
}
function getTgt(t){ const bn=S.devices.filter(d=>t.includes(d.name.toLowerCase())); if(bn.length) return bn; const br=S.devices.filter(d=>t.includes(d.room.toLowerCase())); if(br.length) return br; return S.devices.length?S.devices:[]; }
function afterDev(devs,a,p={}){ renderDevices(); homeStats(); save(); syncGovee(devs,a,p); }

/* ═══════════════════════════════════════════
   CLAUDE API  — with web_search tool
═══════════════════════════════════════════ */
async function callClaude(msg){
  const isNews=/nachrichten|news|aktuell|neueste|schlagzeile|was gibt es neues|heute passiert|wetter heute|aktuell passiert/i.test(msg);

  const sys=`Du bist Jarvis, ein persönlicher KI-Assistent auf einem iPad. Antworte immer auf Deutsch. Du bist höflich, präzise und direkt. Aktuelle Govee-Geräte: ${JSON.stringify(S.devices.map(d=>({name:d.name,on:d.on,br:d.br})))}. Bei Fragen nach Nachrichten, aktuellem Geschehen oder dem Wetter: nutze die Websuche. Antworte kompakt – maximal 3 Sätze.`;

  // Build clean alternating message history
  const msgs=[];
  S.hist.slice(-14).forEach(m=>{
    const role=m.r==='j'?'assistant':'user';
    if(!msgs.length||msgs[msgs.length-1].role!==role) msgs.push({role,content:m.c});
    else msgs[msgs.length-1].content+=' '+m.c; // merge same-role (edge case)
  });
  // Ensure last is user
  if(!msgs.length||msgs[msgs.length-1].role!=='user') msgs.push({role:'user',content:msg});

  const body={model:'claude-sonnet-4-6',max_tokens:1000,system:sys,messages:msgs};
  if(isNews) body.tools=[{type:'web_search_20250305',name:'web_search'}];

  const res=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(body),
  });
  if(!res.ok){ const e=await res.json().catch(()=>({})); throw new Error(e.error?.message||'HTTP '+res.status); }
  const data=await res.json();
  return data.content.filter(c=>c.type==='text').map(c=>c.text).join('')||'(Keine Antwort erhalten)';
}

/* ═══════════════════════════════════════════
   GOVEE API
═══════════════════════════════════════════ */
function setGSt(ok,txt){
  const b=document.getElementById('gst'),t=document.getElementById('gstxt'); if(!b) return;
  b.className='gst '+(ok===true?'ok':ok===false?'err':'idle');
  t.textContent=txt;
}

async function syncDevices(){
  if(!S.goveeKey){ toast('Bitte zuerst API-Key eingeben.'); return; }
  const btn=document.getElementById('syncb'); btn.classList.add('spin');
  setGSt(null,'Verbinde …');
  try{
    const res=await fetch(`${GOVEE}/devices`,{
      headers:{'Govee-API-Key':S.goveeKey,'Content-Type':'application/json'},
    });
    if(!res.ok) throw new Error('HTTP '+res.status+' – API-Key prüfen');
    const d=await res.json();
    if(d.data&&d.data.devices){
      const ex={}; S.devices.forEach(x=>ex[x.id]=x);
      S.devices=d.data.devices.map((x,i)=>{
        const p=ex[x.device]||{};
        return {id:x.device,name:x.deviceName||'Gerät '+(i+1),model:x.model,
          room:p.room||'Standard',on:p.on||false,br:p.br||100,color:p.color||'#ffffff',scene:p.scene||''};
      });
      save(); renderDevices(); fillDefSel();
      setGSt(true,`${S.devices.length} Geräte`);
      toast(`${S.devices.length} Geräte geladen.`);
    }
  }catch(e){ setGSt(false,'Fehler'); toast('Sync fehlgeschlagen: '+e.message); }
  btn.classList.remove('spin');
}

async function gCmd(dev,cmd){
  if(!S.goveeKey) return;
  try{
    await fetch(`${GOVEE}/devices/control`,{
      method:'PUT',
      headers:{'Content-Type':'application/json','Govee-API-Key':S.goveeKey},
      body:JSON.stringify({device:dev.id,model:dev.model,cmd}),
    });
  }catch(e){}
}

async function syncGovee(devs,action,p={}){
  for(const d of devs){
    if(action==='on')         await gCmd(d,{name:'turn',value:'on'});
    else if(action==='off')   await gCmd(d,{name:'turn',value:'off'});
    else if(action==='color') await gCmd(d,{name:'color',value:h2rgb(p.color)});
    else if(action==='brightness') await gCmd(d,{name:'brightness',value:p.brightness});
  }
}
function h2rgb(hex){ return {r:parseInt(hex.slice(1,3),16),g:parseInt(hex.slice(3,5),16),b:parseInt(hex.slice(5,7),16)}; }

/* ═══════════════════════════════════════════
   DEVICE RENDER
═══════════════════════════════════════════ */
function froom(r,el){ S.room=r; document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on')); el.classList.add('on'); renderDevices(); }

function renderDevices(){
  const rooms=['all',...new Set(S.devices.map(d=>d.room))];
  document.getElementById('tabs').innerHTML=rooms.map(r=>`<div class="tab${r===S.room?' on':''}" onclick="froom('${r}',this)">${r==='all'?'Alle':r}</div>`).join('');
  const filt=S.room==='all'?S.devices:S.devices.filter(d=>d.room===S.room);
  let h='';
  if(!S.goveeKey) h+=`<div class="note"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><div>Demo-Modus aktiv. Govee API-Key in den <b>Einstellungen</b> eingeben, um echte Geräte zu steuern.</div></div>`;
  filt.forEach(d=>{
    h+=`<div class="dcard${d.on?' on':''}" id="dc-${d.id}">
      <div class="dtop">
        <div class="dinfo">
          <div class="dico">${['H6601','H6065'].includes(d.model)?'💡':'🌈'}</div>
          <div><div class="dname">${esc(d.name)}</div><div class="dmod">${esc(d.model)} · ${esc(d.room)}</div></div>
        </div>
        <div class="tgl${d.on?' on':''}" onclick="togDev('${d.id}')"></div>
      </div>
      <div class="dctrl">
        <div class="crow"><span class="clbl">Helligkeit</span>
          <input type="range" class="sl" min="0" max="100" value="${d.br}" ${!d.on?'disabled':''} oninput="setBr('${d.id}',this.value,this.nextElementSibling)">
          <span class="cv">${d.br}%</span>
        </div>
        <div class="crow"><span class="clbl">Farbe</span>
          <div class="csw">${COLS.map(c=>`<div class="${d.color===c.h?'on':''}" style="background:${c.h}" title="${c.l}" onclick="setCol('${d.id}','${c.h}',this)"></div>`).join('')}</div>
        </div>
        <div class="crow" style="align-items:flex-start"><span class="clbl">Szene</span>
          <div class="scg">${SCENES.map(s=>`<div class="scb${d.scene===s?' on':''}" onclick="setSc('${d.id}','${s}',this)">${s}</div>`).join('')}</div>
        </div>
      </div>
    </div>`;
  });
  document.getElementById('shbody').innerHTML=h;
}

function togDev(id){ const d=S.devices.find(x=>x.id===id); if(!d) return; d.on=!d.on; afterDev([d],d.on?'on':'off'); }
function setBr(id,v,disp){ const d=S.devices.find(x=>x.id===id); if(!d) return; d.br=parseInt(v); if(disp) disp.textContent=v+'%'; syncGovee([d],'brightness',{brightness:parseInt(v)}); save(); }
function setCol(id,c,el){ const d=S.devices.find(x=>x.id===id); if(!d) return; d.color=c; d.on=true; el.closest('.csw').querySelectorAll('div').forEach(s=>s.classList.remove('on')); el.classList.add('on'); const card=document.getElementById('dc-'+id); if(card){card.classList.add('on');const t=card.querySelector('.tgl');if(t)t.classList.add('on');} syncGovee([d],'color',{color:c}); save(); }
function setSc(id,sc,el){ const d=S.devices.find(x=>x.id===id); if(!d) return; d.scene=d.scene===sc?'':sc; if(d.scene) d.on=true; el.closest('.scg').querySelectorAll('.scb').forEach(s=>s.classList.remove('on')); if(d.scene) el.classList.add('on'); save(); renderDevices(); }

/* ═══════════════════════════════════════════
   WAKEWORD — continuous background listener
═══════════════════════════════════════════ */
let wwRec=null, wwOn=false;

function togWW(){ S.cfg.wakeword=!S.cfg.wakeword; document.getElementById('tww').classList.toggle('on',S.cfg.wakeword); save(); if(S.cfg.wakeword) startWW(); else stopWW(); }

function startWW(){
  if(wwOn) return;
  if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){ toast('Spracherkennung nicht unterstützt.'); return; }
  wwOn=true;
  document.getElementById('wwb').classList.add('show');
  document.getElementById('vhint').textContent='Wakeword aktiv – sagen Sie „Jarvis …"';
  _wwLoop();
}
function _wwLoop(){
  if(!wwOn) return;
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  wwRec=new SR(); wwRec.lang='de-DE'; wwRec.continuous=false; wwRec.interimResults=true; wwRec.maxAlternatives=3;
  wwRec.onresult=(e)=>{
    const last=e.results[e.results.length-1];
    const txts=Array.from(last).map(a=>a.transcript.toLowerCase());
    if(txts.some(t=>/jarvis/.test(t))){
      const cmd=txts[0].replace(/.*?jarvis[,!\s]*/i,'').trim();
      if(cmd.length>2){ wwRec.stop(); onWake(cmd); }
    }
  };
  wwRec.onend=()=>{ if(wwOn) setTimeout(_wwLoop,300); };
  wwRec.onerror=(e)=>{ if(e.error!=='no-speech'&&wwOn) setTimeout(_wwLoop,1000); };
  try{ wwRec.start(); }catch(e){}
}
function stopWW(){
  wwOn=false; if(wwRec){try{wwRec.stop();}catch(e){}wwRec=null;}
  document.getElementById('wwb').classList.remove('show');
  document.getElementById('vhint').textContent='Tippe den Kreis oder sprich „Jarvis …"';
  document.getElementById('orb').classList.remove('wake');
}
function onWake(cmd){
  document.getElementById('orb').classList.add('wake');
  setSt('Jarvis hört …');
  if(S.page!=='chat') navigate('chat');
  setTimeout(()=>{ document.getElementById('ci').value=cmd; sendMsg(); document.getElementById('orb').classList.remove('wake'); if(wwOn) setTimeout(_wwLoop,500); },300);
}

/* ═══════════════════════════════════════════
   MANUAL MIC
═══════════════════════════════════════════ */
let mRec=null, mOn=false;
function toggleMic(){ mOn?stopMic():startMic(); }
function tapOrb(){ mOn?stopMic():startMic(); }
function startMic(){
  if(!S.cfg.speech){ toast('Spracheingabe deaktiviert.'); return; }
  if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){ toast('Sprache nicht unterstützt.'); return; }
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  mRec=new SR(); mRec.lang='de-DE'; mRec.continuous=false; mRec.interimResults=false;
  mRec.onresult=(e)=>{ const t=e.results[0][0].transcript.replace(/^jarvis[,!\s]*/i,'').trim(); stopMic(); document.getElementById('ci').value=t; sendMsg(); };
  mRec.onerror=()=>{ stopMic(); toast('Nicht erkannt.'); };
  mRec.onend=()=>{ if(mOn) stopMic(); };
  mOn=true; mRec.start();
  document.getElementById('bmic').classList.add('rec');
  document.getElementById('orb').classList.add('listening');
  setSt('Zuhören …');
}
function stopMic(){
  mOn=false; if(mRec){try{mRec.stop();}catch(e){}mRec=null;}
  document.getElementById('bmic').classList.remove('rec');
  document.getElementById('orb').classList.remove('listening');
  setSt('Bereit');
}

/* ═══════════════════════════════════════════
   TTS
═══════════════════════════════════════════ */
function speak(txt){
  if(!S.cfg.tts||!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(txt);
  u.lang='de-DE'; u.volume=S.cfg.vol/100; u.rate=1.0; u.pitch=.9;
  window.speechSynthesis.speak(u);
}

/* ═══════════════════════════════════════════
   SETTINGS RENDER & ACTIONS
═══════════════════════════════════════════ */
function renderSettings(){
  const gk=document.getElementById('gkey'); if(gk&&S.goveeKey) gk.value=S.goveeKey;
  document.getElementById('tww').classList.toggle('on',S.cfg.wakeword);
  document.getElementById('tsp').classList.toggle('on',S.cfg.speech);
  document.getElementById('ttts').classList.toggle('on',S.cfg.tts);
  document.getElementById('tanm').classList.toggle('on',S.cfg.anim);
  document.getElementById('tlk').classList.toggle('on',S.cfg.lock);
  document.getElementById('tdrk').classList.toggle('on',S.theme==='dark');
  document.getElementById('volsl').value=S.cfg.vol;
  document.getElementById('volvl').textContent=S.cfg.vol+'%';
  fillDefSel();
  if(S.goveeKey) setGSt(null,'Noch nicht synchronisiert');
}

function saveKey(){ S.goveeKey=document.getElementById('gkey').value; save(); }
function saveDef(){ S.defDev=document.getElementById('defdev').value; save(); }
function fillDefSel(){
  const s=document.getElementById('defdev'); if(!s) return;
  s.innerHTML='<option value="">— Kein Standardgerät —</option>'+S.devices.map(d=>`<option value="${d.id}"${d.id===S.defDev?' selected':''}>${esc(d.name)}</option>`).join('');
}
function togSet(k){ S.cfg[k]=!S.cfg[k]; document.getElementById({speech:'tsp',tts:'ttts',anim:'tanm'}[k]).classList.toggle('on',S.cfg[k]); save(); }
function saveVol(v){ S.cfg.vol=parseInt(v); document.getElementById('volvl').textContent=v+'%'; save(); }
function togTheme(){ S.theme=S.theme==='dark'?'light':'dark'; applyTheme(); save(); }
function applyTheme(){ document.documentElement.setAttribute('data-theme',S.theme); const t=document.getElementById('tdrk'); if(t) t.classList.toggle('on',S.theme==='dark'); }
function setAcc(el){ document.querySelectorAll('.ac').forEach(x=>x.classList.remove('on')); el.classList.add('on'); const r=document.documentElement; r.style.setProperty('--accent',el.dataset.a); r.style.setProperty('--adim',el.dataset.d); r.style.setProperty('--aglow',el.dataset.g); save(); }

/* ═══════════════════════════════════════════
   STATUS / TOAST / UTILS
═══════════════════════════════════════════ */
function setSt(t){ const e=document.getElementById('stxt'); if(e) e.textContent=t; }
let tt=null;
function toast(msg){ const e=document.getElementById('toast'); e.textContent=msg; e.classList.add('show'); clearTimeout(tt); tt=setTimeout(()=>e.classList.remove('show'),2800); }
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function sleep(ms){ return new Promise(r=>setTimeout(r,ms)); }
