<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Jarvis">
<meta name="theme-color" content="#080c14">
<title>Jarvis</title>
<style>
/* ═══ TOKENS ═══ */
:root {
  --bg:#080c14; --surf:#0d1422; --surf2:#111827; --surf3:#1a2235;
  --border:rgba(99,179,237,0.14);
  --accent:#63b3ed; --adim:rgba(99,179,237,0.18); --aglow:rgba(99,179,237,0.38);
  --green:#48bb78; --red:#fc8181; --amber:#f6ad55;
  --text:#e2e8f0; --dim:#718096; --muted:#4a5568;
  --r:16px; --rs:10px;
  --ease:0.22s cubic-bezier(.4,0,.2,1);
  --navh:76px; --sb:env(safe-area-inset-bottom,0px);
}
[data-theme="light"] {
  --bg:#eef2f7; --surf:#ffffff; --surf2:#e4eaf3; --surf3:#d8e2ee;
  --border:rgba(49,130,206,0.16);
  --accent:#2b7cc1; --adim:rgba(43,124,193,0.13); --aglow:rgba(43,124,193,0.32);
  --text:#1a202c; --dim:#4a5568; --muted:#a0aec0;
}

/* ═══ RESET ═══ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{
  background:var(--bg);color:var(--text);
  font-family:-apple-system,'SF Pro Text','Helvetica Neue',sans-serif;
  overflow:hidden;-webkit-tap-highlight-color:transparent;
  transition:background var(--ease),color var(--ease);
  font-size:16px; line-height:1.5;
}

/* ═══ LOCK SCREEN ═══ */
#lock{
  position:fixed;inset:0;z-index:9999;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:24px;padding:48px 32px;
}
#lock.gone{display:none}
.lk-logo{font-size:11px;font-weight:700;letter-spacing:.45em;color:var(--dim);text-transform:uppercase}
.lk-icon{
  width:100px;height:100px;border-radius:50%;
  background:radial-gradient(circle at 38% 38%,rgba(99,179,237,.22),rgba(99,179,237,.04));
  border:1px solid rgba(99,179,237,.28);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 32px rgba(99,179,237,.08);
}
.lk-icon svg{width:40px;height:40px;stroke:var(--accent);stroke-width:1.6;fill:none}
.lk-title{font-size:26px;font-weight:300;letter-spacing:.04em}
.lk-sub{font-size:14px;color:var(--dim);text-align:center;line-height:1.6;max-width:300px}
.lk-form{display:flex;flex-direction:column;gap:14px;width:100%;max-width:340px}
.lk-inp{
  background:var(--surf);border:1.5px solid var(--border);border-radius:var(--r);
  padding:16px 20px;color:var(--text);font-size:17px;outline:none;
  text-align:center;letter-spacing:.12em;
  transition:border-color var(--ease),box-shadow var(--ease);
  font-family:inherit;
}
.lk-inp:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--adim)}
.lk-inp::placeholder{color:var(--muted);letter-spacing:0;font-size:14px}
.lk-btn{
  padding:16px;border-radius:var(--r);border:none;
  background:var(--accent);color:#080c14;
  font-size:16px;font-weight:700;cursor:pointer;letter-spacing:.02em;
  transition:opacity .18s,transform .12s;
}
.lk-btn:active{transform:scale(.97);opacity:.9}
.lk-err{font-size:13px;color:var(--red);text-align:center;min-height:20px;font-weight:500}
.lk-hint{font-size:12px;color:var(--muted);text-align:center;line-height:1.6}
.lk-hint b{color:var(--dim)}

/* ═══ SHELL ═══ */
#app{display:flex;flex-direction:column;height:100dvh;max-width:1024px;margin:0 auto}
.page{display:none;flex:1;min-height:0;overflow-y:auto;overscroll-behavior:contain}
.page.active{display:flex;flex-direction:column}

/* ═══ NAV ═══ */
#nav{
  display:grid;grid-template-columns:repeat(4,1fr);
  background:var(--surf);border-top:1px solid var(--border);
  height:calc(var(--navh) + var(--sb));padding-bottom:var(--sb);
  flex-shrink:0;z-index:100;
}
.nb{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:5px;background:none;border:none;color:var(--muted);cursor:pointer;
  transition:color var(--ease);padding:8px 0;
}
.nb.on{color:var(--accent)}
.nb svg{width:26px;height:26px;stroke-width:1.7;fill:none;stroke:currentColor}
.nb span{font-size:10px;font-weight:600;letter-spacing:.04em}

/* ═══ HOME ═══ */
#page-home{align-items:center;justify-content:space-between;padding:48px 28px 28px;gap:20px}
.wm{font-size:11px;font-weight:700;letter-spacing:.42em;color:var(--dim);text-transform:uppercase}
.clk{text-align:center}
#ct{font-size:clamp(56px,13vw,88px);font-weight:200;letter-spacing:-.03em;line-height:1;font-variant-numeric:tabular-nums}
#cd{font-size:13px;color:var(--dim);margin-top:8px;letter-spacing:.09em;text-transform:uppercase}
.pill{
  display:inline-flex;align-items:center;gap:7px;
  padding:7px 16px;background:var(--adim);border:1px solid var(--border);
  border-radius:999px;font-size:12px;color:var(--accent);letter-spacing:.06em;font-weight:600;
}
.pill-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:pdot 2s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.75)}}

.orb-wrap{position:relative;display:flex;align-items:center;justify-content:center;width:196px;height:196px}
.orb-ring{position:absolute;border-radius:50%;border:1px solid var(--aglow);animation:ore 3s ease-out infinite}
.orb-ring:nth-child(1){inset:0;animation-delay:0s}
.orb-ring:nth-child(2){inset:-18px;animation-delay:.85s}
.orb-ring:nth-child(3){inset:-36px;animation-delay:1.7s}
@keyframes ore{0%{opacity:.6;transform:scale(.88)}100%{opacity:0;transform:scale(1.16)}}
.orb{
  width:148px;height:148px;border-radius:50%;
  background:radial-gradient(circle at 35% 35%,rgba(99,179,237,.26),rgba(99,179,237,.07) 55%,rgba(99,179,237,.02));
  border:1px solid rgba(99,179,237,.32);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  transition:transform .3s,box-shadow .3s;
  box-shadow:0 0 36px rgba(99,179,237,.09),inset 0 0 36px rgba(99,179,237,.04);
}
.orb:hover{transform:scale(1.04)}
.orb.listening{border-color:var(--accent);box-shadow:0 0 56px rgba(99,179,237,.38),inset 0 0 36px rgba(99,179,237,.1);animation:op 1.2s ease-in-out infinite}
.orb.wake{border-color:var(--accent);box-shadow:0 0 72px rgba(99,179,237,.48)}
@keyframes op{0%,100%{transform:scale(1)}50%{transform:scale(1.055)}}
.orb svg{width:50px;height:50px;stroke:var(--accent);stroke-width:1.5;fill:none;opacity:.82}

.hq{display:flex;gap:12px;width:100%}
.qc{flex:1;background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:16px;cursor:pointer;transition:background var(--ease),border-color var(--ease)}
.qc:hover{background:var(--surf2);border-color:var(--aglow)}
.qc-l{font-size:10px;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;margin-bottom:5px;font-weight:600}
.qc-v{font-size:22px;font-weight:300}
.qc-v.g{color:var(--green)}.qc-v.a{color:var(--accent)}

.ww-badge{display:none;align-items:center;gap:7px;padding:6px 14px;background:var(--adim);border:1px solid var(--border);border-radius:999px;font-size:12px;color:var(--accent);font-weight:500}
.ww-badge.show{display:flex}
.ww-d{width:5px;height:5px;border-radius:50%;background:var(--accent);animation:pdot 1s ease-in-out infinite}
.vh{font-size:12px;color:var(--muted);text-align:center;letter-spacing:.04em}

/* ═══ CHAT ═══ */
#page-chat{padding:0}
#ch{padding:18px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;background:var(--surf)}
#ch h2{font-size:17px;font-weight:700;letter-spacing:.04em}
#msgs{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:18px;overscroll-behavior:contain}
.msg{display:flex;gap:10px;animation:mi .24s ease-out both;max-width:88%}
@keyframes mi{from{opacity:0;transform:translateY(9px)}to{opacity:1;transform:translateY(0)}}
.msg.u{flex-direction:row-reverse;align-self:flex-end}
.msg.j{align-self:flex-start}
.av{width:34px;height:34px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700}
.msg.j .av{background:var(--adim);color:var(--accent);border:1px solid var(--border)}
.msg.u .av{background:rgba(72,187,120,.2);color:var(--green);border:1px solid rgba(72,187,120,.2)}
.bub{padding:13px 17px;border-radius:var(--r);font-size:15px;line-height:1.55}
.msg.j .bub{background:var(--surf);border:1px solid var(--border);border-bottom-left-radius:4px}
.msg.u .bub{background:var(--adim);border:1px solid rgba(99,179,237,.26);border-bottom-right-radius:4px}
.mt{font-size:10px;color:var(--muted);margin-top:5px}
.msg.u .mt{text-align:right}
.ti{display:flex;gap:5px;padding:4px 0}
.ti span{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:tb 1.2s ease-in-out infinite}
.ti span:nth-child(2){animation-delay:.2s}.ti span:nth-child(3){animation-delay:.4s}
@keyframes tb{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-7px);opacity:1}}

#cbar{padding:12px 16px calc(12px + var(--sb));border-top:1px solid var(--border);background:var(--surf);display:flex;gap:10px;align-items:flex-end;flex-shrink:0}
#ci{flex:1;background:var(--surf2);border:1.5px solid var(--border);border-radius:999px;padding:12px 18px;color:var(--text);font-size:15px;outline:none;resize:none;height:47px;min-height:47px;max-height:120px;font-family:inherit;line-height:1.4;transition:border-color var(--ease)}
#ci:focus{border-color:var(--accent)}
#ci::placeholder{color:var(--muted)}
.ib{width:47px;height:47px;border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .13s;-webkit-tap-highlight-color:transparent}
.ib:active{transform:scale(.9)}
.ib svg{width:22px;height:22px;stroke:currentColor;stroke-width:2;fill:none}
#bmic{background:var(--adim);border:1px solid var(--border);color:var(--accent)}
#bmic.rec{background:rgba(252,129,129,.2);border-color:rgba(252,129,129,.3);color:var(--red);animation:mp 1s ease-in-out infinite}
@keyframes mp{0%,100%{box-shadow:0 0 0 0 rgba(252,129,129,.3)}50%{box-shadow:0 0 0 8px rgba(252,129,129,0)}}
#bsend{background:var(--accent);color:#080c14}

/* ═══ SMART HOME ═══ */
#page-smarthome{padding:0}
#shh{padding:16px 20px 14px;border-bottom:1px solid var(--border);background:var(--surf);flex-shrink:0}
#shh-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
#shh h2{font-size:17px;font-weight:700;letter-spacing:.04em}
.gst{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;padding:5px 11px;border-radius:999px;border:1px solid var(--border)}
.gst.ok{color:var(--green);border-color:rgba(72,187,120,.25);background:rgba(72,187,120,.09)}
.gst.err{color:var(--red);border-color:rgba(252,129,129,.25);background:rgba(252,129,129,.09)}
.gst.idle{color:var(--muted)}
.gsd{width:5px;height:5px;border-radius:50%;background:currentColor}
.tabs{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab{padding:7px 18px;border-radius:999px;border:1px solid var(--border);background:var(--surf2);color:var(--dim);font-size:13px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all var(--ease)}
.tab.on{background:var(--adim);border-color:var(--aglow);color:var(--accent)}
#shbody{overflow-y:auto;flex:1;padding:16px;display:flex;flex-direction:column;gap:14px}

.dcard{background:var(--surf);border:1.5px solid var(--border);border-radius:var(--r);padding:18px;transition:border-color var(--ease)}
.dcard.on{border-color:rgba(99,179,237,.35)}
.dtop{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.dinfo{display:flex;align-items:center;gap:14px}
.dico{width:44px;height:44px;border-radius:var(--rs);display:flex;align-items:center;justify-content:center;font-size:22px;background:var(--surf2);border:1px solid var(--border);transition:background var(--ease)}
.dcard.on .dico{background:var(--adim)}
.dname{font-size:16px;font-weight:600}
.dmod{font-size:12px;color:var(--muted);margin-top:2px}
.tgl{width:52px;height:30px;border-radius:999px;background:var(--surf2);border:1px solid var(--border);position:relative;cursor:pointer;transition:background .2s,border-color .2s;flex-shrink:0}
.tgl.on{background:var(--accent);border-color:var(--accent)}
.tgl::after{content:'';position:absolute;width:22px;height:22px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .22s cubic-bezier(.4,0,.2,1);box-shadow:0 1px 4px rgba(0,0,0,.3)}
.tgl.on::after{transform:translateX(22px)}

.dctrl{display:flex;flex-direction:column;gap:12px}
.crow{display:flex;align-items:center;gap:10px}
.clbl{font-size:11px;color:var(--muted);width:76px;flex-shrink:0;text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.sl{flex:1;height:5px;border-radius:3px;background:var(--surf2);outline:none;border:none;cursor:pointer;accent-color:var(--accent);-webkit-appearance:none}
.sl::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px rgba(99,179,237,.4);cursor:pointer}
.cv{font-size:13px;color:var(--dim);width:38px;text-align:right;font-variant-numeric:tabular-nums;font-weight:500}
.csw{display:flex;gap:8px;flex-wrap:wrap}
.csw div{width:30px;height:30px;border-radius:50%;border:2.5px solid transparent;cursor:pointer;transition:transform .13s,border-color .13s}
.csw div:hover{transform:scale(1.18)}
.csw div.on{border-color:var(--text)}
.scg{display:flex;gap:8px;flex-wrap:wrap}
.scb{padding:7px 16px;border-radius:999px;border:1px solid var(--border);background:var(--surf2);color:var(--dim);font-size:13px;font-weight:500;cursor:pointer;transition:all var(--ease)}
.scb:hover,.scb.on{background:var(--adim);border-color:var(--aglow);color:var(--accent)}
.note{background:rgba(246,173,85,.1);border:1px solid rgba(246,173,85,.2);border-radius:var(--r);padding:16px;display:flex;gap:12px;align-items:flex-start;font-size:14px;color:var(--amber);line-height:1.55}
.note svg{width:20px;height:20px;flex-shrink:0;margin-top:1px;stroke:currentColor;stroke-width:2;fill:none}

/* ═══ SETTINGS — Large, clear, readable ═══ */
#page-settings{padding:0}
#seth{padding:18px 24px;border-bottom:1px solid var(--border);background:var(--surf);flex-shrink:0}
#seth h2{font-size:20px;font-weight:700;letter-spacing:.03em}
#setbody{overflow-y:auto;flex:1;padding:0 0 32px}

/* Section header */
.shead{
  font-size:12px;font-weight:700;color:var(--dim);letter-spacing:.1em;
  text-transform:uppercase;padding:24px 24px 10px;
}
/* Group card */
.sgrp{
  background:var(--surf);border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  margin-bottom:2px;
}
/* Individual row */
.srow{
  display:flex;align-items:center;justify-content:space-between;
  padding:18px 24px;border-bottom:1px solid var(--border);gap:16px;
  min-height:64px;
}
.srow:last-child{border-bottom:none}
/* Label block */
.sleft{flex:1;min-width:0}
.slbl{font-size:17px;color:var(--text);font-weight:500}
.ssub{font-size:13px;color:var(--dim);margin-top:3px;line-height:1.4}
/* Right side */
.sright{display:flex;align-items:center;gap:10px;flex-shrink:0}

/* Full-width input row */
.srow.col{flex-direction:column;align-items:stretch;gap:12px;padding:18px 24px}
.srow.col .slbl{font-size:17px;font-weight:500}
.sinp{
  background:var(--surf2);border:1.5px solid var(--border);border-radius:var(--rs);
  padding:14px 16px;color:var(--text);font-size:15px;outline:none;
  transition:border-color var(--ease),box-shadow var(--ease);
  font-family:inherit;width:100%;
}
.sinp:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--adim)}
.sinp::placeholder{color:var(--muted)}
.ssel{
  background:var(--surf2);border:1.5px solid var(--border);border-radius:var(--rs);
  padding:12px 14px;color:var(--text);font-size:15px;outline:none;
  font-family:inherit;max-width:100%;width:100%;cursor:pointer;
  transition:border-color var(--ease);
}
.ssel:focus{border-color:var(--accent)}

/* Big toggle */
.btgl{width:56px;height:32px;border-radius:999px;background:var(--surf2);border:1.5px solid var(--border);position:relative;cursor:pointer;transition:background .22s,border-color .22s;flex-shrink:0}
.btgl.on{background:var(--accent);border-color:var(--accent)}
.btgl::after{content:'';position:absolute;width:24px;height:24px;border-radius:50%;background:#fff;top:3px;left:3px;transition:transform .22s cubic-bezier(.4,0,.2,1);box-shadow:0 1px 4px rgba(0,0,0,.3)}
.btgl.on::after{transform:translateX(24px)}

.sbtn{
  padding:12px 22px;border-radius:999px;border:none;
  background:var(--accent);color:#080c14;
  font-size:15px;font-weight:700;cursor:pointer;white-space:nowrap;
  transition:opacity .18s,transform .12s;
}
.sbtn:active{transform:scale(.96);opacity:.88}
.sbtn.ghost{background:transparent;color:var(--accent);border:1.5px solid var(--border)}
.sbtn.danger{background:rgba(252,129,129,.15);color:var(--red);border:1.5px solid rgba(252,129,129,.25)}
.sbtn.danger:hover{background:rgba(252,129,129,.25)}

/* Accent swatches */
.acs{display:flex;gap:10px}
.ac{width:32px;height:32px;border-radius:50%;border:2.5px solid transparent;cursor:pointer;transition:transform .14s,border-color .14s}
.ac.on{border-color:var(--text);transform:scale(1.18)}

/* sync row */
.syncb{padding:10px 18px;border-radius:999px;border:1.5px solid var(--border);background:var(--surf2);color:var(--dim);font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:8px;white-space:nowrap;transition:all var(--ease)}
.syncb:hover{border-color:var(--aglow);color:var(--accent)}
.syncb svg{width:16px;height:16px;stroke:currentColor;stroke-width:2;fill:none}
.syncb.spin svg{animation:rot 1s linear infinite}
@keyframes rot{to{transform:rotate(360deg)}}

/* ═══ TOAST ═══ */
#toast{
  position:fixed;bottom:calc(var(--navh) + var(--sb) + 14px);left:50%;
  transform:translateX(-50%) translateY(18px);
  background:var(--surf3);border:1px solid var(--border);border-radius:999px;
  padding:11px 22px;font-size:14px;color:var(--text);white-space:nowrap;
  opacity:0;transition:opacity .2s,transform .2s;pointer-events:none;z-index:998;
  max-width:92vw;text-align:center;font-weight:500;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
</style>
</head>
<body>

<!-- ═══ LOCK ═══ -->
<div id="lock">
  <div class="lk-logo">J A R V I S</div>
  <div class="lk-icon">
    <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
  </div>
  <div class="lk-title">Gesperrt</div>
  <div class="lk-sub">Geben Sie Ihr Passwort ein um Jarvis zu starten.</div>
  <div class="lk-form">
    <input type="password" class="lk-inp" id="lki" placeholder="Passwort eingeben …" onkeydown="lkKey(event)" autocomplete="current-password">
    <button class="lk-btn" onclick="lkCheck()">Entsperren</button>
    <div class="lk-err" id="lkerr"></div>
    <div class="lk-hint">Passwort vergessen? Geben Sie <b>Baunatal</b> ein — das setzt es auf <b>1234</b> zurück.</div>
  </div>
</div>

<!-- ═══ APP ═══ -->
<div id="app">

<!-- HOME -->
<section class="page active" id="page-home">
  <div class="wm">J A R V I S</div>
  <div class="clk">
    <div id="ct">00:00</div>
    <div id="cd">Laden …</div>
  </div>
